<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1">

    <!-- TOP HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FF6B35"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_subtitle"
            android:textColor="#FFE0CC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- RUPEE COUNTER CARD -->
    <LinearLayout
        android:id="@+id/incomeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="@string/total_rupees_label"
            android:textColor="#999999"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvRupees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0"
            android:textColor="#E65100"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIncomeRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹1.00/sec"
            android:textColor="#FF6B35"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- CHAI STALL IMAGE AREA -->
    <LinearLayout
        android:id="@+id/stallArea"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="#FFF3E0"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/incomeCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🫖"
            android:textSize="56sp" />

        <TextView
            android:id="@+id/tvStallLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roadside Chai Stall — Level 1"
            android:textColor="#795548"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- UPGRADES LABEL -->
    <TextView
        android:id="@+id/upgradesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.1"
        android:text="@string/upgrades_label"
        android:textColor="#999999"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stallArea" />

    <!-- UPGRADES LIST -->
    <LinearLayout
        android:id="@+id/upgradesContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/upgradesLabel">

        <!-- Better Tea -->
        <LinearLayout
            android:id="@+id/upgradeBetterTea"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="6dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBetterTeaName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍵 Better Tea (Lv 0)"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/income_increase_desc"
                    android:textColor="#999999"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBetterTea"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="#4CAF50"
                android:text="₹50"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Faster Service -->
        <LinearLayout
            android:id="@+id/upgradeFasterService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="6dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFasterServiceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Faster Service (Lv 0)"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/income_increase_desc"
                    android:textColor="#999999"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnFasterService"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="#FF9800"
                android:text="₹200"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- More Customers -->
        <LinearLayout
            android:id="@+id/upgradeMoreCustomers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="6dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMoreCustomersName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 More Customers (Lv 0)"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/income_increase_desc"
                    android:textColor="#999999"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnMoreCustomers"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="#9E9E9E"
                android:text="₹800"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- AD BUTTON -->
    <LinearLayout
        android:id="@+id/adBanner"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="#E8F5E9"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/upgradesContainer">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_boost_title"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_boost_subtitle"
                android:textColor="#388E3C"
                android:textSize="11sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnWatchAd"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#4CAF50"
            android:text="@string/btn_watch"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
